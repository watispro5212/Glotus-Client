{
    "name": "glotus-client",
    "author": "Murka",
    "version": "3.4",
    "description": "An excellent Moomoo.io hack for a comfortable gaming experience",
    "license": "MIT",
    "private": true,
    "module": "src/index.ts",
    "type": "module",
    "scripts": {
        "host": "bun run hoster.ts",
        "dev": "cross-env NODE_ENV=development bun build src/index.ts --outdir dist --watch --target browser",
        "build": "cross-env NODE_ENV=production bun run build.ts",
        "private": "cross-env NODE_ENV=production bun run privateBuild.ts",
        "start": "concurrently \"bun run host\" \"bun run dev\""
    },
    "keywords": [
        "hack",
        "mod",
        "cheat",
        "script",
        "userscript",
        "io",
        "tampermonkey",
        "game",
        "browser"
    ],
    "devDependencies": {
        "@types/bun": "latest",
        "concurrently": "^9.1.2",
        "cross-env": "^7.0.3",
        "js-confuser": "^2.0.0",
        "terser": "^5.40.0",
        "type-fest": "^4.41.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "dependencies": {
        "google-closure-compiler": "^20250721.0.0"
    }
}
